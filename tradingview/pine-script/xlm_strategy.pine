//@version=5
//@version=6
indicator("XLM Decision Support - Public Sample", overlay=true, max_labels_count=500)

//----------------------------------------------------
// PUBLIC-SAFE INPUTS
// These are intentionally generic defaults.
// Replace privately with optimized values if needed.
//----------------------------------------------------

// Timeframes
setupTf  = input.timeframe("120", "Setup / Confirmation Timeframe")
exitTf   = input.timeframe("240", "Exit Timeframe")

// RSI inputs
rsiLen               = input.int(14, "RSI Length", minval=2)
setupUpperThreshold  = input.float(75.0, "Setup: Prior High RSI Threshold", step=0.1)
setupLowerThreshold  = input.float(20.0, "Setup: Pullback RSI Threshold", step=0.1)
confirmCrossLevel    = input.float(25.0, "Confirmation: RSI Cross-Up Level", step=0.1)
exitRsiThreshold     = input.float(78.0, "Exit: High RSI Threshold", step=0.1)

// MACD inputs
macdFast   = input.int(12, "MACD Fast Length", minval=1)
macdSlow   = input.int(26, "MACD Slow Length", minval=1)
macdSignal = input.int(9, "MACD Signal Length", minval=1)

// Optional filters
useMacdExitSlope = input.bool(true, "Use MACD rollover exit")
showLabels       = input.bool(true, "Show chart labels")
showBg           = input.bool(true, "Highlight signal bars")

//----------------------------------------------------
// HELPER FUNCTIONS
//----------------------------------------------------
f_rsi(_src, _len) =>
    ta.rsi(_src, _len)

f_macd_line(_src, _fast, _slow, _sig) =>
    [macdLine, signalLine, histLine] = ta.macd(_src, _fast, _slow, _sig)
    [macdLine, signalLine, histLine]

//----------------------------------------------------
// SETUP TIMEFRAME DATA
//----------------------------------------------------
setupRsi = request.security(syminfo.tickerid, setupTf, f_rsi(close, rsiLen), barmerge.gaps_off, barmerge.lookahead_off)

[setupMacd, setupSignal, setupHist] = request.security(
    syminfo.tickerid,
    setupTf,
    f_macd_line(close, macdFast, macdSlow, macdSignal),
    barmerge.gaps_off,
    barmerge.lookahead_off
)

// EXIT TIMEFRAME DATA
exitRsi = request.security(syminfo.tickerid, exitTf, f_rsi(close, rsiLen), barmerge.gaps_off, barmerge.lookahead_off)

[exitMacd, exitSignal, exitHist] = request.security(
    syminfo.tickerid,
    exitTf,
    f_macd_line(close, macdFast, macdSlow, macdSignal),
    barmerge.gaps_off,
    barmerge.lookahead_off
)

//----------------------------------------------------
// SETUP STATE LOGIC
// Public-safe version of:
// "RSI previously hot, then washed out"
//----------------------------------------------------
var bool xlmSetupArmed = false

hadHighRsiRecently = ta.highest(setupRsi, 50) > setupUpperThreshold
pulledBackDeep     = setupRsi < setupLowerThreshold

if hadHighRsiRecently and pulledBackDeep
    xlmSetupArmed := true

// Reset arm after confirmation or exit
//----------------------------------------------------
// CONFIRMATION LOGIC
// Public-safe version of:
// "RSI recovers and MACD confirms"
//----------------------------------------------------
rsiRecoveryConfirm = ta.crossover(setupRsi, confirmCrossLevel)
macdBullConfirm    = ta.crossover(setupMacd, setupSignal)

initialSetupSignal = xlmSetupArmed and pulledBackDeep
buyConfirmSignal   = xlmSetupArmed and rsiRecoveryConfirm and macdBullConfirm

if buyConfirmSignal
    xlmSetupArmed := false

//----------------------------------------------------
// EXIT LOGIC
// Public-safe version of:
// "Higher timeframe RSI hot OR MACD rolling over"
//----------------------------------------------------
macdRollingOver = exitMacd > exitSignal and exitMacd < exitMacd[1]
sellByRsi       = exitRsi > exitRsiThreshold
sellByMacd      = useMacdExitSlope and macdRollingOver

sellSignal = sellByRsi or sellByMacd

//----------------------------------------------------
// PLOTS
//----------------------------------------------------
plotshape(initialSetupSignal, title="XLM Initial Buy Setup", style=shape.circle, location=location.belowbar, size=size.tiny, text="SETUP")
plotshape(buyConfirmSignal, title="XLM Buy Confirmed", style=shape.triangleup, location=location.belowbar, size=size.small, text="BUY")
plotshape(sellSignal, title="XLM Sell", style=shape.triangledown, location=location.abovebar, size=size.small, text="SELL")

bgcolor(showBg and initialSetupSignal ? color.new(color.orange, 85) : na)
bgcolor(showBg and buyConfirmSignal ? color.new(color.green, 85) : na)
bgcolor(showBg and sellSignal ? color.new(color.red, 85) : na)

// Optional labels
if showLabels and initialSetupSignal
    label.new(bar_index, low, "XLM Setup\nRSI pullback armed", style=label.style_label_up, textcolor=color.white, color=color.orange)

if showLabels and buyConfirmSignal
    label.new(bar_index, low, "XLM Buy Confirmed\nRSI recovery + MACD cross", style=label.style_label_up, textcolor=color.white, color=color.green)

if showLabels and sellSignal
    label.new(bar_index, high, "XLM Sell\nHTF RSI or MACD rollover", style=label.style_label_down, textcolor=color.white, color=color.red)

//----------------------------------------------------
// ALERTS
//----------------------------------------------------
alertcondition(
    initialSetupSignal,
    title="XLM Initial Buy Setup",
    message="XLM Initial Buy Setup: public sample logic triggered | {{ticker}} @ {{close}} | {{timenow}}"
)

alertcondition(
    buyConfirmSignal,
    title="XLM BUY CONFIRMED",
    message="XLM BUY CONFIRMED: public sample logic triggered | {{ticker}} @ {{close}} | {{timenow}}"
)

alertcondition(
    sellSignal,
    title="XLM SELL",
    message="XLM SELL: public sample exit logic triggered | {{ticker}} @ {{close}} | {{timenow}}"
)
